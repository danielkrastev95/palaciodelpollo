# ═══════════════════════════════════════════════════════════════
# Palacio del Pollo — Variables de Entorno
# Copia este archivo a .env.local y rellena los valores
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Supabase (REQUERIDO)
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────
# Administración (REQUERIDO)
# Dos variables separadas:
#   - ADMIN_PASSWORD: contraseña que teclea el usuario (mín. 12 caracteres)
#   - ADMIN_SECRET_KEY: clave criptográfica para firmar cookies (mín. 32 caracteres)
# Generar ADMIN_SECRET_KEY con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=tu_contrasena_de_al_menos_12_caracteres
ADMIN_SECRET_KEY=64_caracteres_hex_aleatorios_generados_con_crypto

# ─────────────────────────────────────────────────────────────
# Email con Resend (OPCIONAL)
# Si no se configura, los emails no se envían pero la app funciona
# Obtener en: https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM=El Palacio del Pollo <noreply@tudominio.com>
RESTAURANT_EMAIL=info@palaciopollo.es

# ─────────────────────────────────────────────────────────────
# Sentry (OPCIONAL)
# Monitoreo de errores en producción
# Obtener en: https://sentry.io/settings/projects/
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_AUTH_TOKEN=sntrys_xxxxx
SENTRY_ORG=tu-organizacion
SENTRY_PROJECT=palacio-del-pollo

# ─────────────────────────────────────────────────────────────
# Site URL (OPCIONAL)
# URL canónica para SEO y emails
# Default: https://palaciodpollo.es
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://palaciodpollo.es
